# ── Supabase (obrigatório) ────────────────────────────────────────────────
# Vai ao teu projeto Supabase → Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Telegram Bot (serverless no Vercel) ───────────────────────────────────
BOT_TOKEN=1234567890:telegram-bot-token
CHAT_ID=123456789
TIMEZONE=Europe/Lisbon

# Segurança opcional do webhook
TELEGRAM_WEBHOOK_SECRET=change_me_long_random_string

# Endpoint para setup do webhook (opcional, usado em /api/setup-webhook)
WEBHOOK_SETUP_SECRET=change_me_long_random_string
# WEBHOOK_BASE_URL=https://teu-projeto.vercel.app

# ── Vercel ────────────────────────────────────────────────────────────────
# Adiciona estas variáveis em: Vercel → Project → Settings → Environment Variables
# (copia os mesmos valores de cima sem o prefixo VITE_... não! mantém VITE_)
